#!name = PingMe&WeTalk
#!desc = PingMe跟WeTalk每日签到，支持多账号。分流指定到包含所有节点的round-robin策略组。多账号使用方法：打开获取token开关登录不同的账号，点击我的页面。⚠️不要从app里面直接退出登录，卸载app重新安装，登录另一个需要签到的账号，以此类推
#!date = 2026-4-16
#!author = 怎么肥事[https://t.me/Nzmgs]
#!icon = https://raw.githubusercontent.com/axhani/icon/refs/heads/main/pingme&wetalk.png
#!loon_version = 3.2.4(787)

[Argument]
arg1 = switch,true,tag=PingMe任务
arg2 = switch,true,tag=WeTalk任务
arg3 = switch,true,tag=PM'token
arg4 = switch,true,tag=WT'token
arg5 = input,"0 */5 * * *",tag=PM定时
arg6 = input,"0 */5 * * *",tag=WT定时

[Rule]
DOMAIN, api.pingmeapp.net, PROXY
DOMAIN, api.wetalkapp.com, PROXY

[Script]
cron {arg5} script-path=https://axhani.pages.dev/refs/heads/main/Script%20/Tasks/PingMe.js, timeout=600,enable= {arg1},tag=PingMe签到任务
cron {arg6} script-path=https://axhani.pages.dev/refs/heads/main/Script%20/Tasks/WeTalk.js, timeout=600,enable= {arg2},tag=WeTalk签到任务
http-request ^https:\/\/api\.pingmeapp\.net\/app\/queryBalanceAndBonus script-path=https://axhani.pages.dev/refs/heads/main/Script%20/Tasks/PingMe.js, timeout=300, enable = {arg3}, tag=PingMe (token）
http-request ^https:\/\/api\.wetalkapp\.com\/app\/queryBalanceAndBonus script-path=https://axhani.pages.dev/refs/heads/main/Script%20/Tasks/WeTalk.js, timeout=300, enable = {arg4}, tag=WeTalk（token）
[MITM]
hostname = api.pingmeapp.net, api.wetalkapp.com
